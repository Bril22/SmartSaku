generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())

  accounts     FinAccount[]
  debts        Debt[]
  categories   Category[]
  transactions Transaction[]
  bills        RecurringBill[]
  planned      PlannedTransaction[]
  snapshots    MonthlySnapshot[]
  settings     Settings?
  imports      ImportBatch[]
  goals        Goal[]
  memberships  SpaceMember[]
}

model Space {
  id        String   @id @default(cuid())
  name      String
  personal  Boolean  @default(false)
  createdAt DateTime @default(now())

  members      SpaceMember[]
  invites      SpaceInvite[]
  accounts     FinAccount[]
  debts        Debt[]
  categories   Category[]
  transactions Transaction[]
  planned      PlannedTransaction[]
  goals        Goal[]
  imports      ImportBatch[]
}

model SpaceMember {
  id       String   @id @default(cuid())
  spaceId  String
  space    Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     String   @default("MEMBER")
  joinedAt DateTime @default(now())

  @@unique([spaceId, userId])
}

model SpaceInvite {
  id        String   @id @default(cuid())
  spaceId   String
  space     Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  email     String
  invitedBy String
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@unique([spaceId, email])
  @@index([email])
}

model ImportBatch {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  spaceId   String?
  space     Space?   @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  fileName  String
  status    String   @default("DRAFT")
  rows      Json
  createdAt DateTime @default(now())
}

enum AccountType {
  BANK
  SAVINGS
  EWALLET
  CASH
}

model FinAccount {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  type      AccountType
  balance   BigInt      @default(0)
  archived  Boolean     @default(false)
  hidden    Boolean     @default(false)
  primary   Boolean     @default(false)
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())

  spaceId      String?
  space        Space?               @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  planned      PlannedTransaction[]
  corrections  BalanceCorrection[]
}

enum DebtStatus {
  ACTIVE
  PAID_OFF
}

model Debt {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  lender    String
  color     String     @default("#E8A07C")
  status    DebtStatus @default(ACTIVE)
  createdAt DateTime   @default(now())

  spaceId     String?
  space       Space?              @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  schedule    DebtScheduleEntry[]
  payments    DebtPayment[]
  adjustments DebtAdjustment[]

  @@unique([spaceId, lender])
}

// planned installment for a given month (month = first day of month, UTC)
model DebtScheduleEntry {
  id      String   @id @default(cuid())
  debtId  String
  debt    Debt     @relation(fields: [debtId], references: [id], onDelete: Cascade)
  month   DateTime @db.Date
  planned BigInt

  @@unique([debtId, month])
}

enum PaymentStatus {
  PAID
  PARTIAL
  SKIPPED
}

model DebtPayment {
  id            String        @id @default(cuid())
  debtId        String
  debt          Debt          @relation(fields: [debtId], references: [id], onDelete: Cascade)
  month         DateTime      @db.Date
  amount        BigInt
  paidDate      DateTime      @default(now())
  status        PaymentStatus @default(PAID)
  transactionId String?

  @@index([debtId, month])
}

// manual correction of remaining balance: positive = debt grew, negative = shrank
model DebtAdjustment {
  id        String   @id @default(cuid())
  debtId    String
  debt      Debt     @relation(fields: [debtId], references: [id], onDelete: Cascade)
  month     DateTime @db.Date
  delta     BigInt
  reason    String   @default("")
  createdAt DateTime @default(now())
}

enum TxKind {
  NORMAL
  BALANCE_ADJUSTMENT
}

enum CategoryType {
  INCOME
  EXPENSE
}

model Category {
  id     String       @id @default(cuid())
  userId String
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name   String
  type   CategoryType
  icon   String       @default("💸")
  budget BigInt       @default(0)

  spaceId      String?
  space        Space?               @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  bills        RecurringBill[]
  planned      PlannedTransaction[]

  @@unique([spaceId, name, type])
}

enum Direction {
  IN
  OUT
}

model Transaction {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId     String
  account       FinAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  categoryId    String?
  category      Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  date          DateTime   @default(now())
  amount        BigInt
  direction     Direction
  note          String     @default("")
  spaceId       String?
  space         Space?     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  plannedId     String?
  plannedMonth  DateTime?  @db.Date
  importBatchId String?
  transferId    String?
  kind          TxKind    @default(NORMAL)

  @@unique([plannedId, plannedMonth])
  @@index([userId, date])
}

model RecurringBill {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  amount     BigInt
  dueDay     Int
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  active     Boolean   @default(true)
}

model PlannedTransaction {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  amount     BigInt
  direction  Direction
  spaceId    String?
  space      Space?      @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  dayOfMonth Int         @default(1)
  accountId  String?
  account    FinAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  categoryId String?
  category   Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  active     Boolean     @default(true)
  createdAt  DateTime    @default(now())
}

model Goal {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  icon         String    @default("🎯")
  spaceId      String?
  space        Space?    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  targetAmount BigInt
  targetDate   DateTime? @db.Date
  note         String    @default("")
  advice       String    @default("")
  advisedAt    DateTime?
  createdAt    DateTime  @default(now())

  contributions GoalContribution[]
}

model GoalContribution {
  id            String   @id @default(cuid())
  goalId        String
  goal          Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  amount        BigInt
  transactionId String?
  createdAt     DateTime @default(now())
}

model MonthlySnapshot {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month          DateTime @db.Date
  totalSavings   BigInt
  totalDebt      BigInt
  incomeReceived BigInt

  @@unique([userId, month])
}

model ExchangeRate {
  code       String   @id
  ratePerIdr Float
  fetchedAt  DateTime @default(now())
}

model Settings {
  userId          String @id
  user            User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  currency        String @default("IDR")
  monthlyIncome   BigInt @default(0)
  monthlyExpense  BigInt @default(0)
  // long-term projection assumptions (percent per year)
  salaryGrowthPct Float  @default(5)
  inflationPct    Float  @default(3)
  savingsRatePct  Float  @default(2)
}

model AppMeta {
  key   String @id
  value String
}

/// audit trail for balances corrected without creating a transaction
model BalanceCorrection {
  id        String     @id @default(cuid())
  accountId String
  account   FinAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  userId    String
  before    BigInt
  after     BigInt
  reason    String     @default("")
  createdAt DateTime   @default(now())

  @@index([accountId, createdAt])
}
