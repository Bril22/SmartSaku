generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String?
  /// bumped to invalidate every existing session for this user
  sessionVersion Int    @default(0)
  /// set when the account is linked to a Google identity
  googleId     String?  @unique
  image        String?
  createdAt    DateTime @default(now())

  accounts     FinAccount[]
  debts        Debt[]
  categories   Category[]
  transactions Transaction[]
  bills        RecurringBill[]
  planned      PlannedTransaction[]
  settings     Settings?
  imports      ImportBatch[]
  goals        Goal[]
  memberships  SpaceMember[]
  templates    TransactionTemplate[]
  pushSubs     PushSubscription[]
  nativeTokens NativePushToken[]
  holdings     Holding[]
}

model Space {
  id        String   @id @default(cuid())
  name      String
  personal  Boolean  @default(false)
  createdAt DateTime @default(now())

  members      SpaceMember[]
  invites      SpaceInvite[]
  accounts     FinAccount[]
  debts        Debt[]
  categories   Category[]
  transactions Transaction[]
  planned      PlannedTransaction[]
  goals        Goal[]
  imports      ImportBatch[]
  templates    TransactionTemplate[]
  holdings     Holding[]
}

model SpaceMember {
  id       String   @id @default(cuid())
  spaceId  String
  space    Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     String   @default("MEMBER")
  joinedAt DateTime @default(now())

  @@unique([spaceId, userId])
}

model SpaceInvite {
  id        String   @id @default(cuid())
  spaceId   String
  space     Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  email     String
  invitedBy String
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@unique([spaceId, email])
  @@index([email])
}

model ImportBatch {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  spaceId   String?
  space     Space?   @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  fileName  String
  status    String   @default("DRAFT")
  rows         Json
  createdAt    DateTime @default(now())
  transactions Transaction[]
}

enum AccountType {
  BANK
  SAVINGS
  EWALLET
  CASH
}

model FinAccount {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  type      AccountType
  balance   BigInt      @default(0)
  archived  Boolean     @default(false)
  hidden    Boolean     @default(false)
  primary   Boolean     @default(false)
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())

  spaceId      String?
  space        Space?               @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  planned      PlannedTransaction[]
  corrections  BalanceCorrection[]
  templates    TransactionTemplate[]
}

enum DebtStatus {
  ACTIVE
  PAID_OFF
}

model Debt {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  lender    String
  color     String     @default("#E8A07C")
  status    DebtStatus @default(ACTIVE)
  /// annual interest rate, percent (for the payoff engine)
  aprPct    Float      @default(0)
  /// minimum monthly payment, minor units (snowball/avalanche floor)
  minPayment BigInt    @default(0)
  /// bank | card | paylater | pinjol | kpr | vehicle | personal | other
  kind      String     @default("other")
  createdAt DateTime   @default(now())

  spaceId     String?
  space       Space?              @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  schedule    DebtScheduleEntry[]
  payments    DebtPayment[]
  adjustments DebtAdjustment[]

  @@unique([spaceId, lender])
}

// planned installment for a given month (month = first day of month, UTC)
model DebtScheduleEntry {
  id      String   @id @default(cuid())
  debtId  String
  debt    Debt     @relation(fields: [debtId], references: [id], onDelete: Cascade)
  month   DateTime @db.Date
  planned BigInt

  @@unique([debtId, month])
}

enum PaymentStatus {
  PAID
  PARTIAL
  SKIPPED
}

model DebtPayment {
  id            String        @id @default(cuid())
  debtId        String
  debt          Debt          @relation(fields: [debtId], references: [id], onDelete: Cascade)
  month         DateTime      @db.Date
  amount        BigInt
  paidDate      DateTime      @default(now())
  status        PaymentStatus @default(PAID)
  transactionId String?

  @@index([debtId, month])
}

// manual correction of remaining balance: positive = debt grew, negative = shrank
model DebtAdjustment {
  id        String   @id @default(cuid())
  debtId    String
  debt      Debt     @relation(fields: [debtId], references: [id], onDelete: Cascade)
  month     DateTime @db.Date
  delta     BigInt
  reason    String   @default("")
  createdAt DateTime @default(now())
}

enum ChatRole {
  USER
  AI
}

enum TxKind {
  NORMAL
  BALANCE_ADJUSTMENT
}

enum CategoryType {
  INCOME
  EXPENSE
}

model Category {
  id     String       @id @default(cuid())
  userId String
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name   String
  type   CategoryType
  icon   String       @default("💸")
  budget BigInt       @default(0)

  spaceId      String?
  space        Space?               @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  bills        RecurringBill[]
  planned      PlannedTransaction[]
  templates    TransactionTemplate[]

  @@unique([spaceId, name, type])
}

model TransactionTemplate {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  spaceId    String?
  space      Space?      @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  name       String
  emoji      String      @default("⭐")
  direction  Direction   @default(OUT)
  amount     BigInt      @default(0)
  categoryId String?
  category   Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  accountId  String?
  account    FinAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  note       String      @default("")
  sortOrder  Int         @default(0)
  createdAt  DateTime    @default(now())

  @@index([spaceId, sortOrder])
}

enum Direction {
  IN
  OUT
}

model Transaction {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId     String
  account       FinAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  categoryId    String?
  category      Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  date          DateTime   @default(now())
  amount        BigInt
  direction     Direction
  note          String     @default("")
  spaceId       String?
  space         Space?     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  plannedId     String?
  plannedFrom   PlannedTransaction? @relation("PlannedRecorded", fields: [plannedId], references: [id], onDelete: SetNull)
  plannedMonth  DateTime?  @db.Date
  importBatchId String?
  importBatch   ImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  /// groups the two legs of a transfer; not a foreign key
  transferId    String?
  kind          TxKind    @default(NORMAL)
  /// id minted on the device for offline entries; makes syncing idempotent
  clientId      String?   @unique

  @@unique([plannedId, plannedMonth])
  @@index([userId, date])
  @@index([spaceId, date])
  @@index([spaceId, accountId, date])
  @@index([spaceId, categoryId, date])
  @@index([importBatchId])
  @@index([transferId])
}

model RecurringBill {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  amount     BigInt
  dueDay     Int
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  active     Boolean   @default(true)
}

model PlannedTransaction {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  amount     BigInt
  direction  Direction
  spaceId    String?
  space      Space?      @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  dayOfMonth Int         @default(1)
  accountId  String?
  account    FinAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  categoryId String?
  category   Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  active     Boolean     @default(true)
  recorded   Transaction[] @relation("PlannedRecorded")
  /// first month this item applies to; null means it has always applied
  startMonth DateTime?   @db.Date
  /// last month it applies to; null means it repeats with no end
  endMonth   DateTime?   @db.Date
  createdAt  DateTime    @default(now())
}

model Goal {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  icon         String    @default("🎯")
  spaceId      String?
  space        Space?    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  targetAmount BigInt
  targetDate   DateTime? @db.Date
  note         String    @default("")
  createdAt    DateTime  @default(now())

  contributions GoalContribution[]
  messages      GoalMessage[]
}

model GoalContribution {
  id            String   @id @default(cuid())
  goalId        String
  goal          Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  amount        BigInt
  transactionId String?
  createdAt     DateTime @default(now())
}


model ExchangeRate {
  code       String   @id
  ratePerIdr Float
  fetchedAt  DateTime @default(now())
}

model Settings {
  userId          String @id
  user            User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  currency        String @default("IDR")
  /// day of month the budget period starts on (1 = calendar month)
  monthStartDay   Int    @default(1)
  monthlyIncome   BigInt @default(0)
  monthlyExpense  BigInt @default(0)
  // long-term projection assumptions (percent per year)
  salaryGrowthPct Float  @default(5)
  inflationPct    Float  @default(3)
  savingsRatePct  Float  @default(2)
  // notification preferences
  notifyDaily     Boolean @default(false)
  notifyHour      Int     @default(20)
  notifyTz        String  @default("Asia/Jakarta")
  notifyDebts     Boolean @default(true)
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String   @default("")
  createdAt DateTime @default(now())

  @@index([userId])
}

model NotificationLog {
  id     String   @id @default(cuid())
  userId String
  /// dedupe key, e.g. "daily:2026-07-23" or "debt:<id>:2026-07"
  kind   String
  sentAt DateTime @default(now())

  @@unique([userId, kind])
}

model NativePushToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// FCM registration token from the native app
  token     String   @unique
  platform  String   @default("")
  createdAt DateTime @default(now())

  @@index([userId])
}

model Holding {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  spaceId     String?
  space       Space?   @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  /// crypto | stock | gold | fund | other
  kind        String   @default("crypto")
  /// ticker for a live price, e.g. BTC (crypto only)
  symbol      String   @default("")
  name        String   @default("")
  quantity    Float    @default(0)
  /// manual valuation for non-crypto holdings, minor units IDR
  manualValue BigInt   @default(0)
  createdAt   DateTime @default(now())

  @@index([spaceId])
}

model AppMeta {
  key   String @id
  value String
}

/// audit trail for balances corrected without creating a transaction
model BalanceCorrection {
  id        String     @id @default(cuid())
  accountId String
  account   FinAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  userId    String
  before    BigInt
  after     BigInt
  reason    String     @default("")
  createdAt DateTime   @default(now())

  @@index([accountId, createdAt])
}

/// running conversation with Saku-Kun about one goal
model GoalMessage {
  id        String   @id @default(cuid())
  goalId    String
  goal      Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  role      ChatRole
  text      String
  createdAt DateTime @default(now())

  @@index([goalId, createdAt])
}

/// fixed-window rate limiter; one row per key
model RateLimit {
  key         String   @id
  count       Int      @default(0)
  windowStart DateTime @default(now())
}
